# Anthropic — used for OCR (reading recipient names from scanned letters)
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google OAuth2 Credentials
# Create these at https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your_client_id_here
GOOGLE_CLIENT_SECRET=your_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# Google Drive
# The ID of the folder where scanned mail PDFs land
# Get this from the Drive folder URL: drive.google.com/drive/folders/FOLDER_ID_HERE
GOOGLE_DRIVE_FOLDER_ID=your_drive_folder_id_here

# App Config
SESSION_SECRET=change_this_to_a_random_string_in_production
PORT=3000

# How often to check Drive for new mail (in seconds)
POLL_INTERVAL_SECONDS=60
