# Google OAuth2 (same credentials as the mail sorter)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/google/callback
GOOGLE_DRIVE_FOLDER_ID=

# Google account tokens (copy from existing mail sorter DB or re-auth)
GOOGLE_ACCESS_TOKEN=
GOOGLE_REFRESH_TOKEN=

# CompanyBoard ingest endpoint
INGEST_URL=http://localhost:3000/api/mail/ingest
INGEST_SECRET=

# Polling
POLL_INTERVAL_SECONDS=60
PORT=3001
